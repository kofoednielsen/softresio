{
  "imports": {
    "hono": "jsr:@hono/hono@^4.11.4",
    "postgres": "npm:postgres@3.4.7",
    "zod": "npm:zod@^4.3.6"
  },
  "tasks": {
    "run": "deno run --unstable-cron --allow-read --allow-net --allow-sys --allow-env src/main.ts"
    "start": "deno serve --unstable-cron --allow-read --allow-net --allow-sys --allow-env src/main.ts",
    "start-dev": "deno serve --unstable-cron --allow-read --allow-net --allow-sys --allow-env --watch src/main.ts"
  },
  "fmt": {
    "semiColons": false
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
